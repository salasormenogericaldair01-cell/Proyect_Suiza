# Database connection string for PostgreSQL
# Reemplaza usuario, contraseña y host según tu instalación local.
DATABASE_URL="postgresql://postgres:admin123@localhost:5432/sistemaestudiantil?schema=public"

# Secret used by Auth.js for session encryption
# Generate one with: openssl rand -base64 32
AUTH_SECRET="cambia-por-una-clave-segura-larga"

# Initial administrator used only by `npm run db:seed`
SEED_ADMIN_EMAIL="admin@sistema.com"
SEED_ADMIN_PASSWORD="cambia-por-una-clave-segura"

# Opcional: API key para la integración de IA si usas la función de notas.
GEMINI_API_KEY="tu_gemini_api_key_aqui"
