// =============================================
// SISTEMA DE GESTIÓN ESTUDIANTIL
// schema.prisma — Base de datos completa
// =============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
  PARENT
  SUPPORT
}

enum NotificationType {
  GRADE_HIGH
  GRADE_LOW
  GRADE_MEDIUM
  NEW_TASK
  ABSENCE
  ANNOUNCEMENT
  CHAT_MESSAGE
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum EventType {
  EXAM
  TASK
  PROJECT
  HOLIDAY
  MEETING
  OTHER
}

enum GradePeriod {
  TRIMESTER_1
  TRIMESTER_2
  TRIMESTER_3
  FINAL
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role
  photo     String?
  phone     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student          Student?
  parent           Parent?
  teacher          Teacher?
  notifications    Notification[]
  announcements    Announcement[]
  sentMessages     ChatMessage[] @relation("SentMessages")
  receivedMessages ChatMessage[] @relation("ReceivedMessages")
  activityLogs     ActivityLog[]

  @@map("users")
}

model Student {
  id          String  @id @default(uuid())
  userId      String  @unique
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentId    String?
  parent      Parent? @relation(fields: [parentId], references: [id])
  career      String
  cycle       String
  studentCode String? @unique

  grades     Grade[]
  attendance Attendance[]

  @@map("students")
}

model Parent {
  id       String    @id @default(uuid())
  userId   String    @unique
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  children Student[]

  @@map("parents")
}

model Teacher {
  id       String    @id @default(uuid())
  userId   String    @unique
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  subjects Subject[]

  @@map("teachers")
}

model Subject {
  id        String   @id @default(uuid())
  name      String
  code      String?  @unique
  career    String?
  teacherId String?
  teacher   Teacher? @relation(fields: [teacherId], references: [id])

  grades         Grade[]
  attendance     Attendance[]
  academicEvents AcademicEvent[]

  @@map("subjects")
}

model Grade {
  id        String      @id @default(uuid())
  studentId String
  student   Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subjectId String
  subject   Subject     @relation(fields: [subjectId], references: [id])
  score     Float
  period    GradePeriod
  comment   String?
  aiMessage String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@map("grades")
}

model Attendance {
  id        String           @id @default(uuid())
  studentId String
  student   Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subjectId String
  subject   Subject          @relation(fields: [subjectId], references: [id])
  date      DateTime         @db.Date
  status    AttendanceStatus @default(PRESENT)
  note      String?
  createdAt DateTime         @default(now())

  @@unique([studentId, subjectId, date])
  @@map("attendance")
}

model Notification {
  id           String           @id @default(uuid())
  userId       String
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type         NotificationType
  title        String
  message      String
  isRead       Boolean          @default(false)
  gradeId      String?
  attendanceId String?
  createdAt    DateTime         @default(now())

  @@map("notifications")
}

model Announcement {
  id        String   @id @default(uuid())
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  title     String
  content   String
  isPublic  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("announcements")
}

model AcademicEvent {
  id          String    @id @default(uuid())
  title       String
  description String?
  type        EventType
  date        DateTime  @db.Date
  dueDate     DateTime? @db.Date
  subjectId   String?
  subject     Subject?  @relation(fields: [subjectId], references: [id])
  createdAt   DateTime  @default(now())

  @@map("academic_events")
}

model ChatMessage {
  id         String   @id @default(uuid())
  senderId   String
  sender     User     @relation("SentMessages", fields: [senderId], references: [id])
  receiverId String
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id])
  content    String
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@map("chat_messages")
}

model ActivityLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String
  entity    String?
  entityId  String?
  createdAt DateTime @default(now())

  @@map("activity_logs")
}
